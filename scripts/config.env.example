# ─── Icinga2 API ─────────────────────────────────────────────────────────────
ICINGA2_HOST="localhost"
ICINGA2_PORT="5665"
ICINGA2_USER="icingaweb2"
# Leave blank to read from /etc/icinga2/conf.d/api-users.conf at runtime
ICINGA2_PASS=""

# ─── QuestDB ─────────────────────────────────────────────────────────────────
QUESTDB_HOST="localhost"
QUESTDB_PORT="9000"      # REST API port

# Table/query that returns hosts to import.
# Required columns: host_name (string), address (string)
# Optional columns: display_name, os, location, custom_vars (JSON string)
QUESTDB_HOST_QUERY="SELECT host_name, address, os FROM monitoring_hosts WHERE active = true"

# Icinga2 zone/template to use for imported hosts
ICINGA2_HOST_TEMPLATE="generic-host"
ICINGA2_HOST_ZONE="master"
