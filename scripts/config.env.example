# ─── Icinga2 API ─────────────────────────────────────────────────────────────
ICINGA2_HOST="localhost"
ICINGA2_PORT="5665"
ICINGA2_USER="icinga-scripts"

# ─── QuestDB ─────────────────────────────────────────────────────────────────
QUESTDB_HOST="localhost"
QUESTDB_PORT="9000"

# ─── Host import settings ─────────────────────────────────────────────────────
ICINGA2_HOST_TEMPLATE="linux-player"
ICINGA2_HOST_ZONE="master"

# ─── HaloITSM ─────────────────────────────────────────────────────────────────
HALO_URL="https://your-instance.haloitsm.com/api/notify/icinga"

# ─── Icinga2 web UI base URL (used in notification links) ─────────────────────
ICINGA2_WEB_URL="https://your-icinga2.example.com/icingaweb2"
