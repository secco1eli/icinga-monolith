/**
 * API users — generated by setup.sh, do not commit the real file.
 * This example shows the structure and permissions only.
 * Passwords are auto-generated during setup and stored in secrets.env.
 */
object ApiUser "root" {
  password = "<auto-generated>"
  permissions = [ "*" ]
}

object ApiUser "icingaweb2" {
  password = "<auto-generated>"
  permissions = [ "status/query", "actions/*", "objects/modify/*", "objects/query/*" ]
}

object ApiUser "icinga-scripts" {
  password = "<auto-generated>"
  permissions = [ "objects/query/Host", "objects/create/Host", "objects/modify/Host", "objects/delete/Host", "actions/process-check-result" ]
}

object ApiUser "halo-digital-user" {
  password = "<auto-generated>"
  permissions = [ "actions/add-comment", "objects/query/Host", "objects/query/Service" ]
}
